{
  "name": "amplisio/aio",
  "description": "Amplisio AIO for WooCommerce",
  "type": "wordpress-plugin",
  "require": {
    "php": ">=8.1",
    "woocommerce/action-scheduler": "^3.6"
  },
  "autoload": {
    "psr-4": {
      "Amplisio\\AIO\\": "src/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"file_exists('vendor/autoload.php') || exit(0);\""
    ]
  }
}
