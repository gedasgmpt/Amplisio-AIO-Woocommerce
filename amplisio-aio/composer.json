{
  "name": "amplisio/amplisio-aio",
  "description": "Amplisio AIO for WooCommerce plugin skeleton",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.1"
  },
  "autoload": {
    "psr-4": {
      "AmplisioAIO\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AmplisioAIO\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^10.2",
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "scripts": {
    "lint": "phpcs",
    "test": "phpunit"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  }
}
